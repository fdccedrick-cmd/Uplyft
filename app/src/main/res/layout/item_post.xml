<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background">

    <!-- Header: Avatar + Username + Options -->
    <LinearLayout
        android:id="@+id/layoutPostHeader"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivUserAvatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:scaleType="centerCrop"
            android:padding="1dp"
            app:shapeAppearanceOverlay="@style/circleImageView"
            app:strokeWidth="1dp"
            app:strokeColor="#DBDBDB"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="username"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/ivOptions"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more"
            app:tint="@color/on_background"
            android:contentDescription="Options"
            android:padding="4dp"/>

    </LinearLayout>

    <!-- ✅ Square post image with heart overlay — Instagram style -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/imageContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/layoutPostHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ✅ Carousel — replaces single ivPostImage -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vpPostImages"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Transparent overlay for double tap gesture detection -->
        <FrameLayout
            android:id="@+id/doubleTapOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintTop_toTopOf="@id/vpPostImages"
            app:layout_constraintBottom_toBottomOf="@id/vpPostImages"
            app:layout_constraintStart_toStartOf="@id/vpPostImages"
            app:layout_constraintEnd_toEndOf="@id/vpPostImages"/>

        <!-- dots indicator -->
        <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
            android:id="@+id/dotsIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:dotsColor="@android:color/white"
            app:dotsSize="6dp"
            app:dotsSpacing="4dp"
            app:selectedDotColor="@android:color/white"
            app:layout_constraintBottom_toBottomOf="@id/vpPostImages"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvImageCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="#66000000"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="10dp"/>


        <!-- Heart overlay for double-tap animation (Instagram style) -->
        <ImageView
            android:id="@+id/ivHeartOverlay"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_heart_filled"
            app:tint="#FFFFFF"
            android:alpha="0"
            android:visibility="gone"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="Like animation"/>

        <!-- Upload Status Overlay (Gray overlay for pending/uploading/failed posts) -->
        <FrameLayout
            android:id="@+id/uploadStatusOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#99000000"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ProgressBar
                    android:id="@+id/uploadProgressBar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:indeterminateTint="#FFFFFF"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvUploadStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uploading..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/btnRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to retry"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:padding="8dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Action Buttons with Counts -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toBottomOf="@id/imageContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Like Button with Count -->
        <LinearLayout
            android:id="@+id/layoutLike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/ivLike"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_heart_outline"
                app:tint="@color/on_background"
                android:contentDescription="Like"/>

            <TextView
                android:id="@+id/tvLikesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Comment Button with Count -->
        <LinearLayout
            android:id="@+id/layoutComment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/ivComment"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_comment"
                app:tint="@color/on_background"
                android:contentDescription="Comment"/>

            <TextView
                android:id="@+id/tvCommentsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Share Button -->
        <ImageView
            android:id="@+id/ivShare"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_share"
            app:tint="@color/on_background"
            android:contentDescription="Share"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Save Button -->
        <ImageView
            android:id="@+id/ivSave"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bookmark_outline"
            app:tint="@color/on_background"
            android:contentDescription="Save"/>

    </LinearLayout>


    <!-- Caption -->
    <TextView
        android:id="@+id/tvCaption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"
        android:textSize="13sp"
        android:textColor="@color/on_background"
        app:layout_constraintTop_toBottomOf="@id/layoutActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingBottom="12dp"
        android:text="2 hours ago"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        app:layout_constraintTop_toBottomOf="@id/tvCaption"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/tvTimestamp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>