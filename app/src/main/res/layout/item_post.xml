<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background">

    <!-- Header: Avatar + Username + Options -->
    <LinearLayout
        android:id="@+id/layoutPostHeader"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivUserAvatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:scaleType="centerCrop"
            android:padding="1dp"
            app:shapeAppearanceOverlay="@style/circleImageView"
            app:strokeWidth="1dp"
            app:strokeColor="#DBDBDB"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="username"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/ivOptions"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more"
            android:tint="@color/on_background"
            android:contentDescription="Options"
            android:padding="4dp"/>

    </LinearLayout>

    <!-- ✅ Square post image — Instagram style -->
    <ImageView
        android:id="@+id/ivPostImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:background="@color/surface"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/layoutPostHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toBottomOf="@id/ivPostImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivLike"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_heart_outline"
            android:tint="@color/on_background"
            android:padding="8dp"
            android:contentDescription="Like"/>

        <ImageView
            android:id="@+id/ivComment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_comment"
            android:tint="@color/on_background"
            android:padding="8dp"
            android:contentDescription="Comment"/>

        <ImageView
            android:id="@+id/ivShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_share"
            android:tint="@color/on_background"
            android:padding="8dp"
            android:contentDescription="Share"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

    <!-- Likes count -->
    <TextView
        android:id="@+id/tvLikesCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 likes"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/on_background"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutActions"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Caption -->
    <TextView
        android:id="@+id/tvCaption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"
        android:textSize="13sp"
        android:textColor="@color/on_background"
        app:layout_constraintTop_toBottomOf="@id/tvLikesCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingBottom="12dp"
        android:text="2 hours ago"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        app:layout_constraintTop_toBottomOf="@id/tvCaption"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/tvTimestamp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>