<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.uplyft.ui.main.home.HomeFragment"
        android:label="Home" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.uplyft.ui.main.search.SearchFragment"
        android:label="Search" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.uplyft.ui.main.profile.ProfileFragment"
        android:label="Profile" />
    <fragment
        android:id="@+id/selectImageFragment"
        android:name="com.example.uplyft.ui.main.createpost.SelectImageFragment">
        <action
            android:id="@+id/action_selectImageFragment_to_createPostFragment"
            app:destination="@id/createPostFragment"/>
    </fragment>

    <fragment
        android:id="@+id/createPostFragment"
        android:name="com.example.uplyft.ui.main.createpost.CreatePostFragment">
        <argument
            android:name="imageUri"
            app:argType="string"/>
    </fragment>

</navigation>