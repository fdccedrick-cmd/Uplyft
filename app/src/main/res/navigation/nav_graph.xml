<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- ═══════════════════════════════════════════
         DECLARE CHILD FRAGMENTS FIRST
         so actions can reference their IDs
    ═══════════════════════════════════════════ -->

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.uplyft.ui.main.profile.EditProfileFragment"
        android:label="Edit Profile"/>

    <fragment
        android:id="@+id/selectImageFragment"
        android:name="com.example.uplyft.ui.main.createpost.SelectImageFragment"
        android:label="New Post">
        <action
            android:id="@+id/action_selectImageFragment_to_createPostFragment"
            app:destination="@id/createPostFragment"/>
    </fragment>

    <fragment
        android:id="@+id/createPostFragment"
        android:name="com.example.uplyft.ui.main.createpost.CreatePostFragment"
        android:label="New Post">
        <argument
            android:name="imageUri"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/postDetailFragment"
        android:name="com.example.uplyft.ui.main.profile.PostDetailFragment"
        android:label="Posts">
        <argument
            android:name="postId"
            app:argType="string"/>
        <argument
            android:name="userId"
            app:argType="string"/>
        <action
            android:id="@+id/action_postDetailFragment_to_userProfileFragment"
            app:destination="@id/userProfileFragment"/>
        <action
            android:id="@+id/action_postDetailFragment_to_commentsFragment"
            app:destination="@id/commentsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.example.uplyft.ui.main.profile.UserProfileFragment"
        android:label="Profile">
        <argument
            android:name="userId"
            app:argType="string"/>
        <action
            android:id="@+id/action_userProfileFragment_to_postDetailFragment"
            app:destination="@id/postDetailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/commentsFragment"
        android:name="com.example.uplyft.ui.main.comments.CommentsFragment"
        android:label="Comments">
        <argument
            android:name="postId"
            app:argType="string"/>
        <action
            android:id="@+id/action_commentsFragment_to_userProfileFragment"
            app:destination="@id/userProfileFragment"/>
        <action
            android:id="@+id/action_commentsFragment_to_profileFragment"
            app:destination="@id/profileFragment"/>
    </fragment>

    <!-- ═══════════════════════════════════════════
         MAIN TAB FRAGMENTS — bottom nav visible
    ═══════════════════════════════════════════ -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.uplyft.ui.main.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_homeFragment_to_selectImageFragment"
            app:destination="@id/selectImageFragment"/>
        <action
            android:id="@+id/action_homeFragment_to_userProfileFragment"
            app:destination="@id/userProfileFragment"/>
        <action
            android:id="@+id/action_homeFragment_to_commentsFragment"
            app:destination="@id/commentsFragment"/>

    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.uplyft.ui.main.search.SearchFragment"
        android:label="Search"/>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.uplyft.ui.main.profile.ProfileFragment"
        android:label="Profile">
        <argument
            android:name="userId"
            app:argType="string"
            android:defaultValue="@null"
            app:nullable="true"/>
        <action
            android:id="@+id/action_profileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment"/>
        <action
            android:id="@+id/action_profileFragment_to_postDetailFragment"
            app:destination="@id/postDetailFragment"/>
        <action
            android:id="@+id/action_profileFragment_to_commentsFragment"
            app:destination="@id/commentsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.example.uplyft.ui.main.notifications.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications">

        <action
            android:id="@+id/action_notificationsFragment_to_postDetailFragment"
            app:destination="@id/postDetailFragment"/>

        <action
            android:id="@+id/action_notificationsFragment_to_userProfileFragment"
            app:destination="@id/userProfileFragment"/>

    </fragment>

    <!-- add action in homeFragment -->
    <action
        android:id="@+id/action_homeFragment_to_notificationsFragment"
        app:destination="@id/notificationsFragment"/>

</navigation>